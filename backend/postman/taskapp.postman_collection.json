{
  "info": {
    "name": "TaskApp API",
    "description": "Pruebas automatizadas de la API de tareas academicas.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:4000" }
  ],
  "item": [
    {
      "name": "Health check",
      "request": { "method": "GET", "url": "{{base_url}}/health" },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
              "pm.test('Respuesta contiene status ok', function () {",
              "  pm.expect(pm.response.json().status).to.eql('ok');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Listar tareas",
      "request": { "method": "GET", "url": "{{base_url}}/api/tareas" },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
              "pm.test('La respuesta es un arreglo', function () {",
              "  pm.expect(Array.isArray(pm.response.json())).to.be.true;",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Crear tarea",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{base_url}}/api/tareas",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"titulo\": \"Tarea creada desde Postman\",\n  \"materia\": \"Desarrollo Web\",\n  \"fecha_entrega\": \"2026-07-01\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 201', function () { pm.response.to.have.status(201); });",
              "pm.test('Devuelve la tarea creada', function () {",
              "  pm.expect(pm.response.json().titulo).to.eql('Tarea creada desde Postman');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Crear tarea sin titulo (debe fallar)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{base_url}}/api/tareas",
        "body": { "mode": "raw", "raw": "{}" }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 400 por validacion', function () { pm.response.to.have.status(400); });"
            ]
          }
        }
      ]
    }
  ]
}
